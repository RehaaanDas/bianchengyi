function print(string){
    i; i = 0;
    char;
    loop:
        char = *(string+i);
        cout(char);
        i = i + 2;
    if(char){; goto loop;};

    return 0;
};
function sdiff(one, two){   
    i; i =0;
    difc;
    onechar; twochar;
    comp:
        onechar = *(one+i);
        twochar = *(two+i);
        difc = difc + onechar - twochar;
        i = i + 2;
    if(onechar){;goto comp;}

    return difc;
};