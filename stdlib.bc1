function sdiff(one, two){   
    i; i =0;
    difc;
    onechar; twochar;
    stdlibloop0:
        onechar = *(one+i);
        twochar = *(two+i);
        difc = difc + onechar - twochar;
        i = i + 2;
    if(onechar){;goto stdlibloop0;}

    return difc;
};